<?xml version='1.0' encoding='utf-8'?>
<!--
  config.xml — SciCalcApp
  Chapter 5: adds battery-status and network-information plugin declarations.
-->
<widget id="com.example.myfirstapp"
        version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>MyFirstApp</name>

    <description>
        A cross-platform scientific calculator and system monitor built
        chapter-by-chapter following Building Cross-Platform Mobile and
        Web Apps for Engineers and Scientists.
    </description>

    <author email="programmingwithvusi@gmail.com" href="https://vuka-systems-automation.com">
        Levious
    </author>

    <content src="index.html" />

    <!-- App icons: web SVG for in-app UI and placeholders for native icons
         (native launcher icons should be PNGs placed under res/icons/) -->
    <icon src="www/img/icon.svg" />
    <!-- Android launcher icon placeholders (add actual PNGs before building) -->
    <platform name="android">
        <icon density="ldpi" src="res/icons/android/icon-36.png" />
        <icon density="mdpi" src="res/icons/android/icon-48.png" />
        <icon density="hdpi" src="res/icons/android/icon-72.png" />
        <icon density="xhdpi" src="res/icons/android/icon-96.png" />
        <icon density="xxhdpi" src="res/icons/android/icon-144.png" />
        <icon density="xxxhdpi" src="res/icons/android/icon-192.png" />
    </platform>

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <!-- Chapter 5: device monitoring plugins -->
    <plugin name="cordova-plugin-battery-status"      spec="^3.0.0" />
    <plugin name="cordova-plugin-network-information" spec="^3.0.0" />
    <plugin name="cordova-plugin-device"              spec="^2.0.0" />

</widget>
