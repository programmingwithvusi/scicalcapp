<?xml version='1.0' encoding='utf-8'?>
<!--
  config.xml — SciCalcApp
  Chapter 2: this file is what Cordova reads during `cordova build`.
  Every field here maps to a row in the Build Information panel.
-->
<widget id="com.example.myfirstapp"
        version="1.0.0"
        xmlns="http://www.w3.org/ns/widgets"
        xmlns:cdv="http://cordova.apache.org/ns/1.0">

    <name>MyFirstApp</name>

    <description>
        A cross-platform scientific calculator and system monitor built
        chapter-by-chapter following Building Cross-Platform Mobile and
        Web Apps for Engineers and Scientists.
    </description>

    <author email="dev@example.com" href="https://example.com">
        Levious
    </author>

    <content src="index.html" />

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <!-- 
    Android: splash/status bar matches "bg and bg-header" tokens
    <preference name="BackgroundColor" value="0xff0f1117" />
    <preference name="StatusBarBackgroundColor" value="0xff13151f" />
-->
</widget>
